---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { urlize } from '../../lib/slug';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const counts = new Map<string, number>();
for (const post of posts) {
  for (const c of post.data.categories ?? []) {
    counts.set(c, (counts.get(c) ?? 0) + 1);
  }
}
const terms = [...counts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Categories">
    <div class="list-page">
        <h1>Categories</h1>
        <p class="page-description">모든 categories의 목록입니다.</p>

        <div class="taxonomy-grid">
            {terms.map(([name, count]) => (
                <a href={`/categories/${urlize(name)}/`} class="taxonomy-item">
                    <h2>{name}</h2>
                    <p>{count}개의 포스트</p>
                </a>
            ))}
        </div>

        {terms.length === 0 && (
            <div class="empty-state">
                <p>아직 categories가 없습니다.</p>
            </div>
        )}
    </div>
</BaseLayout>
